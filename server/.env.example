# Server port (default: 3001)
PORT=3001

# Optional: OSRM-compatible routing base URL (default: https://router.project-osrm.org)
# OSRM_BASE_URL=

# Optional: OpenRouteService API key — when set, /api/maps/route prefers ORS (road-following, free tier limits apply) before OSRM
# ORS_API_KEY=

# Optional: YouTube Data API v3 for music search (see docs/API_KEYS_SETUP.md)
# YOUTUBE_API_KEY=
