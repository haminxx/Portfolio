# Backend API URL (for GitHub profile data)
# Local: http://localhost:3001
# Production: https://your-api.onrender.com (after deploying server/ to Render)
VITE_API_URL=

# Optional: YouTube Data API v3 key (HTTP referrer–restricted) for in-app search
VITE_YOUTUBE_API_KEY=

# Optional: Mapbox access token (URL-restricted) for road directions in the Map app when the backend proxy is unavailable
# https://account.mapbox.com/access-tokens/
VITE_MAPBOX_ACCESS_TOKEN=

# Optional: OpenWeatherMap API key (imperial units). Without it, the weather widget uses Open-Meteo (still °F).
# https://openweathermap.org/api
VITE_OPENWEATHER_API_KEY=

# Optional: TMDB API key for real movie/TV posters and metadata in the Netflix window (free).
# https://www.themoviedb.org/settings/api
VITE_TMDB_API_KEY=

# Optional: Apple MapKit JS JWT token for Apple Maps tiles, search, and directions.
# Without it, the map falls back to MapLibre GL with CARTO dark tiles.
# Maps ID: maps.me.christianjameslee
# Generate key at: https://developer.apple.com/account/resources/authkeys/list
VITE_MAPKIT_TOKEN=
